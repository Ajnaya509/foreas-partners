# ─── SUPABASE ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ─── BACKEND ──────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:3002

# ─── CROSS-DOMAIN AUTH SYNC (7.4.4) ──────────────────────────────────────────
# En local : laisser VIDE → cookies scoped à localhost (pas de cross-subdomain)
# En production Vercel : mettre ".foreas.xyz" (avec le point initial)
# Effet : session login sur foreas.xyz reconnue sur partners.foreas.xyz et vice-versa
# ⚠️ Ne JAMAIS mettre une valeur ici pour le dev local — casse l'auth localhost
NEXT_PUBLIC_COOKIE_DOMAIN=
